{
  "manifest_version": 3,
  "name": "Password Manager",
  "version": "1.0",
  "description": "Communicates with local password manager server",
  "permissions": ["activeTab","storage"],
  "host_permissions": ["http://localhost:7878/*", "<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}